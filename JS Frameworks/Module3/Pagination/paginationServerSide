//If millions of data
//sends a request to the server for the first data page. This request usually includes parameters like page=1 and limit=10
// clicks “Next” or a specific page number, the client sends a new request to the server for that new page (e.g., page=2&limit=10)

const [currentPage, setCurrentPage] = useState(1);
const [products, setProducts] = useState([]);

const API = 'https://v2.api.noroff.dev/old-games';
const LIMIT = 5;

function GamesList() {
  const [games, setGames] = useState([]);
  const [currentPage, setCurrentPage] = useState(1);
  const [totalPages, setTotalPages] = useState(0);
  const [isLoading, setIsLoading] = useState(false);

  useEffect(() => {
    const fetchGames = async () => {
      setIsLoading(true);
      const response = await fetch(`${API}?page=${currentPage}&limit=${LIMIT}`); // send page number to server
      const result = await response.json();
      setGames(result.data); // items for this page only
      setTotalPages(result.meta.pageCount); // how many pages exist total
      setIsLoading(false);
    };

    fetchGames();
  }, [currentPage]); // re-runs every time page changes

  if (isLoading) return <p>Loading...</p>;

  return (
    <div>
      {games.map((game) => (
        <p key={game.id}>{game.name}</p>
      ))}

      <button
        disabled={currentPage === 1}
        onClick={() => setCurrentPage((p) => p - 1)}
      >
        Prev
      </button>
      <span>
        {' '}
        Page {currentPage} of {totalPages}{' '}
      </span>
      <button
        disabled={currentPage === totalPages}
        onClick={() => setCurrentPage((p) => p + 1)}
      >
        Next
      </button>
    </div>
  );
}
